{
  "name": "roxwood-hospital-system",
  "private": true,
  "version": "1.0.0",
  "description": "Dev-only asset pipeline for shared-hosting deployment (outputs static files to public/assets).",
  "scripts": {
    "build": "npm run vendor:copy && npm run css:build",
    "css:build": "tailwindcss -c tailwind.config.js -i ./resources/css/app.css -o ./public/assets/app.css --min",
    "css:watch": "tailwindcss -c tailwind.config.js -i ./resources/css/app.css -o ./public/assets/app.css --watch",
    "vendor:copy": "node ./scripts/copy-vendor.mjs"
  },
  "dependencies": {
    "alpinejs": "3.14.9",
    "htmx.org": "1.9.12"
  },
  "devDependencies": {
    "autoprefixer": "10.4.21",
    "daisyui": "4.12.14",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17"
  }
}

