#--------------------------------------------------------------------
# ROXWOOD (DEV ADMIN LOGIN)
#--------------------------------------------------------------------

# Set one of the following:
# - ROXWOOD_ADMIN_PASSWORD (plain text, dev only)
# - ROXWOOD_ADMIN_PASSWORD_HASH (recommended; output from PHP password_hash)

ROXWOOD_ADMIN_EMAIL = 'admin@example.com'
# ROXWOOD_ADMIN_PASSWORD = ''
# ROXWOOD_ADMIN_PASSWORD_HASH = ''

# Cookie secure flag (set true on HTTPS hosting)
ROXWOOD_COOKIE_SECURE = false
